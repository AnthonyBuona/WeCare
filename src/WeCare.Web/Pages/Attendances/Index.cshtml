@page
@using WeCare.Web.Pages.Attendances
@using WeCare.Permissions
@using Microsoft.AspNetCore.Authorization
@using Volo.Abp.AspNetCore.Mvc.UI.Layout
@using WeCare.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<WeCareResource> L
@inject IAuthorizationService AuthorizationService
@inject IPageLayout PageLayout
@model IndexModel
@{
    ViewBag.Title = L["Menu:Attendances"].Value;
    PageLayout.Content.Title = L["Menu:Attendances"].Value;
    PageLayout.Content.BreadCrumb.Add(L["Menu:Attendances"].Value);
    PageLayout.Content.MenuItemName = "Attendances";
}

@section scripts {
    <abp-script src="/Pages/Attendances/index.js" />
}

<div class="welcoming-banner">
    <div class="row align-items-center">
        <div class="col-md-8 col-12">
            <div class="d-flex align-items-center">
                <div class="rounded-circle bg-white shadow-sm d-flex align-items-center justify-content-center me-3" style="width: 56px; height: 56px; font-size: 1.5rem; color: var(--color-mint-teal-base);">
                    <i class="fa fa-check-square-o"></i>
                </div>
                <div>
                    <h2 class="mb-0 text-dark fw-bold" style="color: var(--color-lavender-dark) !important;">@L["Menu:Attendances"]</h2>
                    <p class="text-muted mb-0">Rastreabilidade e controle de frequência das sessões terapêuticas infantis.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-12 text-md-end mt-3 mt-md-0">
            @if (await AuthorizationService.IsGrantedAsync(WeCarePermissions.Attendances.Create))
            {
                <button id="NewAttendanceButton" class="btn btn-interactive">
                    <i class="fa fa-plus me-2"></i> Registrar Frequência
                </button>
            }
        </div>
    </div>
</div>

<div class="glass-card card border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <abp-table striped-rows="true" id="AttendancesTable" class="table align-items-center table-flush table-hover mb-0" />
        </div>
    </div>
</div>
