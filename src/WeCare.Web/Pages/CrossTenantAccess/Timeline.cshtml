@page
@model WeCare.Web.Pages.CrossTenantAccess.TimelineModel
@{
    ViewBag.Title = "Linha do Tempo Multidiciplinar Compartilhada - WeCare";
}

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.75);
        --glass-border: rgba(255, 255, 255, 0.4);
        --glass-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.06);
        --mint-teal: hsl(168, 76%, 42%);
        --lavender-purple: hsl(265, 80%, 65%);
        --pastel-origin: rgba(26, 188, 156, 0.15);
    }

    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(12px) saturate(180%);
        -webkit-backdrop-filter: blur(12px) saturate(180%);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        box-shadow: var(--glass-shadow);
        padding: 24px;
        margin-bottom: 24px;
    }

    .glass-input {
        background: rgba(255, 255, 255, 0.5);
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        padding: 12px;
        transition: all 0.2s ease;
    }

    .glass-input:focus {
        background: rgba(255, 255, 255, 0.9);
        border-color: var(--mint-teal);
        box-shadow: 0 0 0 3px rgba(46, 204, 113, 0.2);
    }

    .gradient-btn-lavender {
        background: linear-gradient(135deg, var(--lavender-purple), hsl(265, 75%, 58%));
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 24px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

    .gradient-btn-lavender:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(155, 89, 182, 0.4);
        color: white;
    }

    /* Pastel Badge */
    .clinic-origin-badge {
        background-color: var(--pastel-origin);
        color: hsl(168, 76%, 28%);
        border: 1px solid rgba(26, 188, 156, 0.3);
        font-weight: bold;
        font-size: 0.85rem;
        padding: 6px 14px;
        border-radius: 20px;
        display: inline-block;
    }

    /* Elegant Timeline */
    .timeline-container {
        position: relative;
        padding-left: 32px;
        margin-left: 16px;
        border-left: 2px solid rgba(0, 0, 0, 0.08);
    }

    .timeline-item {
        position: relative;
        margin-bottom: 32px;
    }

    .timeline-badge-node {
        position: absolute;
        left: -48px;
        top: 2px;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        text-align: center;
        line-height: 32px;
        font-size: 0.95rem;
        z-index: 2;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .timeline-date {
        font-size: 0.85rem;
        font-weight: bold;
        color: var(--lavender-purple);
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .bg-light-info { background: rgba(52, 152, 219, 0.1); }
    .text-info { color: #2980b9 !important; }
    .bg-light-success { background: rgba(46, 204, 113, 0.1); }
    .text-success { color: #27ae60 !important; }
    .bg-light-warning { background: rgba(241, 196, 15, 0.15); }
    .text-warning { color: #d35400 !important; }
    .bg-light-danger { background: rgba(231, 76, 60, 0.1); }
    .text-danger { color: #c0392b !important; }
</style>

<div class="container py-4">
    @if (!Model.IsAccessGranted)
    {
        <div class="row justify-content-center py-5">
            <div class="col-md-6">
                <div class="glass-card text-center py-5 shadow-lg">
                    <img src="https://img.icons8.com/bubbles/140/000000/key.png" alt="Lock Key" class="mb-4" />
                    <h2 class="fw-bold mb-3 text-dark">Portal do Terapeuta Externo</h2>
                    <p class="text-secondary mb-4">
                        Insira um token de acesso temporário gerado pelo responsável legal para visualizar a linha do tempo do paciente.
                    </p>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger border-0 rounded-3 mb-4 py-3" role="alert">
                            <i class="fa fa-exclamation-triangle me-2"></i> @Model.ErrorMessage
                        </div>
                    }

                    <form method="post" asp-page-handler="SubmitToken">
                        <div class="mb-4">
                            <input asp-for="Token" placeholder="Cole o token wctk_..." class="form-control text-center glass-input" style="font-size: 1.1rem; letter-spacing: 1px;" required />
                        </div>
                        <button type="submit" class="gradient-btn-lavender w-100 py-3">
                            <i class="fa fa-unlock-alt me-2"></i> Validar e Acessar Prontuário
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <!-- Informações do Paciente -->
            <div class="col-12 mb-4">
                <div class="glass-card" style="background: rgba(255, 255, 255, 0.85);">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <div>
                            <div class="d-flex align-items-center gap-3 flex-wrap">
                                <span class="clinic-origin-badge">
                                    <i class="fa fa-hospital-o me-1"></i> Origem: @Model.OriginClinicName
                                </span>
                                <span class="badge bg-purple text-uppercase py-2 px-3 fw-bold" style="background-color: var(--lavender-purple);">Acesso Autorizado LGPD</span>
                            </div>
                            <h1 class="display-6 fw-bold mt-2 text-dark mb-0">@Model.Patient.Name</h1>
                            <div class="text-secondary mt-1">
                                <span class="me-3"><strong>Idade:</strong> @Model.Patient.Age anos</span>
                                <span><strong>Diagnóstico principal:</strong> @Model.Patient.Diag</span>
                            </div>
                        </div>
                        <div>
                            <a href="/CrossTenantAccess/Timeline" class="btn btn-outline-secondary rounded-3">
                                <i class="fa fa-sign-out"></i> Encerrar Acesso
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Timeline Chronológica -->
            <div class="col-lg-8 mx-auto">
                <div class="glass-card">
                    <h3 class="fw-bold text-dark mb-4"><i class="fa fa-history text-muted me-2"></i> Evolução Multidisciplinar</h3>

                    @if (!Model.TimelineItems.Any())
                    {
                        <div class="text-center py-5">
                            <h5 class="text-muted">Nenhum histórico médico encontrado para este paciente.</h5>
                        </div>
                    }
                    else
                    {
                        <div class="timeline-container">
                            @foreach (var item in Model.TimelineItems)
                            {
                                <div class="timeline-item">
                                    <!-- Node Circle -->
                                    <div class="timeline-badge-node @item.IconClass">
                                        <i class="fa"></i>
                                    </div>

                                    <!-- Date Header -->
                                    <div class="timeline-date">@item.Date.ToString("dd MMM yyyy")</div>

                                    <!-- Card Content -->
                                    <div class="glass-card p-3 mb-0" style="background: rgba(255, 255, 255, 0.45); margin-bottom: 0;">
                                        <div class="d-flex justify-content-between align-items-start gap-2">
                                            <h5 class="fw-bold text-dark mb-1">@item.Title</h5>
                                            <span class="badge rounded-pill @item.BadgeClass text-sm">@item.Type</span>
                                        </div>
                                        <p class="text-dark my-2" style="font-size: 0.95rem; white-space: pre-line;">@item.Description</p>
                                        <div class="text-muted text-xs border-top pt-2 mt-2" style="font-size: 0.8rem;">
                                            <i class="fa fa-info-circle me-1"></i> @item.AdditionalInfo
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
