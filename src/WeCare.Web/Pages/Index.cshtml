                                <div class="card-body position-relative z-1">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="text-uppercase ls-1 mb-1" style="font-size: 0.7rem; color: rgba(0,0,0,0.5);">Relatórios Pendentes</h6>
                                            <h2 class="display-4 fw-bold mb-0 text-dark">@Model.Stats.PendingReports</h2>
                                        </div>
                                        <div class="icon-shape bg-white rounded-circle shadow" style="color: #f7971e; position: relative;">
                                            <i class="fa fa-file-text-o fa-lg"></i>
                                            @if (Model.Stats.PendingReports > 0)
                                            {
                                                <span class="badge bg-danger rounded-pill position-absolute" style="top: -6px; right: -6px; font-size: 0.65rem;">!</span>
                                            }
                                        </div>
                                    </div>
                                    <p class="mt-3 mb-0 text-sm" style="color: rgba(0,0,0,0.5);">
                                        @if (Model.Stats.PendingReports > 0)
                                        {
                                            <span class="fw-bold text-danger"><i class="fa fa-exclamation-circle"></i> Aguardando assinatura</span>
                                        }
                                        else
                                        {
                                            <span class="fw-bold text-dark"><i class="fa fa-check-circle"></i> Tudo em dia</span>
                                        }
                                    </p>
                                </div>
                            </div>
                        </a>
                    </div>

                    <!-- Upcoming Sessions (compact list) -->
                    <div class="col-md-12 col-xl-4 mb-4">
                        <div class="card border-0 h-100 shadow-sm">
                            <div class="card-header bg-white border-0 pb-0 pt-3 px-3">
                                <h6 class="text-uppercase text-muted ls-1 mb-0" style="font-size: 0.7rem;"><i class="fa fa-clock-o me-1"></i> Próximas Sessões de Hoje</h6>
                            </div>
                            <div class="card-body px-3 py-2">
                                @if (Model.Stats.UpcomingConsultationsToday.Any())
                                {
                                    <ul class="list-group list-group-flush">
                                        @foreach (var session in Model.Stats.UpcomingConsultationsToday)
                                        {
                                            <li class="list-group-item px-0 py-2 border-bottom d-flex align-items-center justify-content-between">
                                                <div class="d-flex align-items-center">
                                                    <div class="rounded-circle d-flex align-items-center justify-content-center me-2 text-white fw-bold" style="width: 36px; height: 36px; font-size: 0.85rem; background: linear-gradient(135deg, #4da391 0%, #8c7fcd 100%); flex-shrink: 0;">
                                                        @session.PatientName.Substring(0, 1)
                                                    </div>
                                                    <div>
                                                        <span class="fw-bold text-dark d-block" style="font-size: 0.88rem; line-height: 1.2;">@session.PatientName</span>
                                                        <small class="text-muted" style="font-size: 0.75rem;"><i class="fa fa-user-md me-1"></i>@session.TherapistName</small>
                                                    </div>
                                                </div>
                                                <span class="badge bg-light text-dark border rounded-pill fw-bold" style="font-size: 0.75rem;">
                                                    <i class="fa fa-clock-o me-1 text-primary"></i>@session.DateTime.ToString("HH:mm")
                                                </span>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <div class="text-center py-3">
                                        <div class="text-muted mb-1" style="font-size: 1.5rem;">📅</div>
                                        <small class="text-muted">Nenhuma sessão agendada para agora.</small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Monthly Attendance Widget (D3) -->
                    <div class="col-md-12 col-xl-8 mb-4">
                        <div class="card border-0 h-100 shadow-sm glass-card">
                            <div class="card-header bg-transparent border-0 pb-0 pt-3 px-3 d-flex justify-content-between align-items-center">
                                <h6 class="text-uppercase text-muted ls-1 mb-0"><i class="fa fa-bar-chart me-1"></i> Frequência Mensal (Últimos 4 Meses)</h6>
                                <div class="d-none d-sm-flex gap-3 text-xs fw-semibold">
                                    <span class="d-flex align-items-center gap-1"><span class="d-inline-block rounded-circle" style="width: 10px; height: 10px; background-color: var(--color-mint-teal-base);"></span> Presenças</span>
                                    <span class="d-flex align-items-center gap-1"><span class="d-inline-block rounded-circle" style="width: 10px; height: 10px; background-color: #ef4444;"></span> Ausências</span>
                                    <span class="d-flex align-items-center gap-1"><span class="d-inline-block rounded-circle" style="width: 10px; height: 10px; background-color: #f59e0b;"></span> Cancelados</span>
                                </div>
                            </div>
                            <div class="card-body p-3 d-flex flex-column justify-content-around">
                                @if (Model.Stats.MonthlyAttendanceStats.Any())
                                {
                                    @foreach (var stat in Model.Stats.MonthlyAttendanceStats)
                                    {
                                        var total = stat.PresentCount + stat.AbsentCount + stat.CancelledCount;
                                        var presentPct = total > 0 ? Math.Round(((double)stat.PresentCount / total) * 100, 1) : 0;
                                        var absentPct = total > 0 ? Math.Round(((double)stat.AbsentCount / total) * 100, 1) : 0;
                                        var cancelledPct = total > 0 ? Math.Round(((double)stat.CancelledCount / total) * 100, 1) : 0;

                                        <div class="mb-3">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="fw-bold text-dark" style="font-size: 0.9rem;">@stat.MonthName</span>
                                                <span class="text-xs text-xs-mobile text-muted">
                                                    @if (total > 0)
                                                    {
                                                        <strong class="text-success" style="color: var(--color-mint-teal-base) !important;">@stat.PresenceRate% Presença</strong>
                                                        <span>(@stat.PresentCount P, @stat.AbsentCount A, @stat.CancelledCount C)</span>
                                                    }
                                                    else
                                                    {
                                                        <span>Sem atendimentos registrados</span>
                                                    }
                                                </span>
                                            </div>
                                            <div class="progress" style="height: 14px; border-radius: 20px; background-color: rgba(0,0,0,0.05); overflow: hidden;">
                                                @if (total > 0)
                                                {
                                                    <div class="progress-bar" role="progressbar" style="width: @(presentPct.ToString("G", System.Globalization.CultureInfo.InvariantCulture))%; background-color: var(--color-mint-teal-base); transition: width 0.6s ease;" aria-valuenow="@presentPct" aria-valuemin="0" aria-valuemax="100"></div>
                                                    <div class="progress-bar" role="progressbar" style="width: @(absentPct.ToString("G", System.Globalization.CultureInfo.InvariantCulture))%; background-color: #ef4444; transition: width 0.6s ease;" aria-valuenow="@absentPct" aria-valuemin="0" aria-valuemax="100"></div>
                                                    <div class="progress-bar" role="progressbar" style="width: @(cancelledPct.ToString("G", System.Globalization.CultureInfo.InvariantCulture))%; background-color: #f59e0b; transition: width 0.6s ease;" aria-valuenow="@cancelledPct" aria-valuemin="0" aria-valuemax="100"></div>
                                                }
                                                else
                                                {
                                                    <div class="progress-bar bg-light" role="progressbar" style="width: 100%;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-center py-4">
                                        <div class="text-muted mb-2" style="font-size: 2rem;">📊</div>
                                        <p class="text-muted">Nenhum dado mensal disponível para exibição.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>

