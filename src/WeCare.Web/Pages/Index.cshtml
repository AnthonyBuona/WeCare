@page
@model WeCare.Web.Pages.IndexModel
@using WeCare.Web.Menus
@using Volo.Abp.AspNetCore.Mvc.UI.Layout
@using Microsoft.AspNetCore.Mvc.Localization
@using WeCare.Localization
@using Volo.Abp.Users
@using WeCare.PeriodicReports
@inject IPageLayout PageLayout
@inject IHtmlLocalizer<WeCareResource> L
@inject ICurrentUser CurrentUser
@{
    ViewBag.PageTitle = L["Home"];
    PageLayout.Content.MenuItemName = WeCareMenus.Home;
}

@section styles {
    <abp-style src="/Pages/Index.css" />
    <style>
        :root {
            --color-mint-teal-light: hsl(168, 76%, 90%);
            --color-mint-teal-base: hsl(168, 76%, 42%);
            --color-mint-teal-dark: hsl(168, 76%, 20%);
            --color-lavender-light: hsl(262, 70%, 95%);
            --color-lavender-base: hsl(262, 70%, 68%);
            --color-lavender-dark: hsl(262, 70%, 30%);
            --gradient-welcoming: linear-gradient(135deg, var(--color-mint-teal-light) 0%, var(--color-lavender-light) 100%);
            --gradient-welcoming-interactive: linear-gradient(135deg, var(--color-mint-teal-base) 0%, var(--color-lavender-base) 100%);
        }

        .welcoming-banner {
            background: var(--gradient-welcoming);
            border-radius: 20px;
            padding: 2.2rem;
            margin-bottom: 2.2rem;
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        .btn-interactive {
            background: var(--gradient-welcoming-interactive);
            border: none;
            color: white !important;
            font-weight: 600;
            padding: 10px 24px;
            border-radius: 20px;
            box-shadow: 0 4px 15px rgba(45, 206, 137, 0.2);
            transition: all 0.3s ease;
        }

        .btn-interactive:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(45, 206, 137, 0.3);
            filter: brightness(1.05);
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(12px) saturate(180%);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.08);
            overflow: hidden;
        }

        .status-badge-0 {
            background-color: #ffeeb3 !important;
            color: #856404 !important;
            padding: 6px 12px;
            border-radius: 20px;
            font-weight: 600;
        }

        .status-badge-1 {
            background-color: #bbf7d0 !important;
            color: #15803d !important;
            padding: 6px 12px;
            border-radius: 20px;
            font-weight: 600;
        }

        .status-badge-2 {
            background-color: #e0f2fe !important;
            color: #0369a1 !important;
            padding: 6px 12px;
            border-radius: 20px;
            font-weight: 600;
        }

        /* Mobile responsivity & Touch Target enhancements */
        @@media (max-width: 767.98px) {
            input, select, textarea, .form-control {
                font-size: 16px !important; /* Prevents native iOS input zoom */
                min-height: 44px; /* Premium touch target sizing */
            }
            .btn-interactive, .btn {
                min-height: 44px; /* Premium touch target sizing */
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }
        }

        @@media (max-width: 575.98px) {
            .wizard-step-node span {
                display: none !important; /* Hides text labels of stepper on small mobile viewports to prevent squishing */
            }
            .wizard-step-node {
                width: 44px;
            }
            .welcoming-banner {
                padding: 1.5rem; /* Reduces padding on smaller viewports to maximize usable space */
            }
            .card-body {
                padding: 1.25rem !important;
            }
            .text-xs-mobile {
                font-size: 0.72rem !important;
            }
        }
    </style>
}

@section scripts {
    <abp-script src="/Pages/Index.js" />
}

@if (Model.IsResponsible)
{
    <!-- PORTAL DO RESPONSÁVEL (A UI DO CARLOS) -->
    <div class="welcoming-banner shadow-sm mb-4">
        <div class="row align-items-center">
            <div class="col-lg-8 col-12">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-white shadow-sm d-flex align-items-center justify-content-center me-3" style="width: 64px; height: 64px; font-size: 1.8rem; color: #4da391; background: #fff;">
                        🌸
                    </div>
                    <div>
                        <h2 class="mb-0 text-dark fw-bold" style="color: hsl(262, 70%, 30%) !important;">Olá, @(Model.ParentProfile?.NameResponsible ?? "Responsável")!</h2>
                        <p class="text-muted mb-0">Bem-vindo ao Portal da Família do WeCare. Acompanhe abaixo o desenvolvimento clínico de seus filhos em tempo real.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-12 text-lg-end mt-3 mt-lg-0">
                <span class="badge bg-white text-primary border rounded-pill px-3 py-2 shadow-sm fw-bold">
                    <i class="fa fa-heart me-1 text-danger"></i> Espaço Terapêutico Acolhedor
                </span>
            </div>
        </div>
    </div>

    <!-- Meus Dependentes -->
    <h4 class="fw-bold text-dark mb-3"><i class="fa fa-users me-2 text-primary"></i>Dependentes Assistidos</h4>
    <div class="row mb-4">
        @foreach (var patient in Model.MyPatients)
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card h-100 border-0 shadow-sm rounded-4 p-3" style="background: rgba(255,255,255,0.75); border: 1px solid rgba(255,255,255,0.5);">
                    <div class="d-flex align-items-center">
                        <div class="rounded-circle text-white d-flex align-items-center justify-content-center me-3 font-weight-bold" style="width: 50px; height: 50px; font-size: 1.25rem; background: linear-gradient(135deg, #4da391 0%, #8c7fcd 100%);">
                            @patient.Name.Substring(0, 1)
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-0">@patient.Name</h5>
                            <small class="text-muted d-block"><i class="fa fa-birthday-cake me-1"></i> Nascimento: @patient.BirthDate.ToString("dd/MM/yyyy")</small>
                            @if (!string.IsNullOrEmpty(patient.Diag))
                            {
                                <span class="badge bg-light text-primary border rounded-pill mt-1" style="font-size: 0.8rem;">CID: @patient.Diag</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row">
        <!-- Feed Transacional Diário -->
        <div class="col-lg-7 mb-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h4 class="fw-bold text-dark mb-0"><i class="fa fa-calendar-check-o me-2 text-primary"></i>Feed Transacional Diário</h4>
                <span class="text-muted text-sm">Atualizações diárias</span>
            </div>
            
            @if (Model.RecentConsultations.Any())
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var consultation in Model.RecentConsultations)
                    {
                        var patientName = Model.MyPatients.FirstOrDefault(p => p.Id == consultation.PatientId)?.Name ?? "Paciente";
                        <div class="card border-0 shadow-sm rounded-4 p-3" style="background: rgba(255,255,255,0.75); border-left: 5px solid #4da391 !important;">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <span class="badge bg-light text-success border rounded-pill me-2">Consulta Realizada</span>
                                    <small class="text-muted"><i class="fa fa-clock-o me-1"></i>@consultation.DateTime.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                                <small class="text-muted">Acompanhado por: <strong>Terapeuta</strong></small>
                            </div>
                            
                            <h6 class="fw-bold text-dark mb-1">@patientName - Evolução na Sessão:</h6>
                            <p class="text-muted mb-3" style="font-size: 0.9rem; line-height: 1.5;">@consultation.Description</p>
                            
                            <div class="p-3 rounded-3" style="background: hsl(35, 100%, 96%); border: 1px dashed #f7a47b;">
                                <h6 class="fw-bold text-warning mb-1" style="color: #df8b62 !important;"><i class="fa fa-lightbulb-o me-1"></i>💡 Orientações Práticas para Casa (Home Guidance)</h6>
                                <p class="mb-0 text-dark" style="font-size: 0.88rem; line-height: 1.4;">
                                    @Model.GetHomeGuidance(consultation, patientName)
                                </p>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm text-center p-4 rounded-4" style="background: rgba(255,255,255,0.6);">
                    <div class="fs-1 text-muted mb-2">📅</div>
                    <h6 class="fw-bold text-dark mb-1">Nenhuma sessão registrada recentemente</h6>
                    <p class="text-muted text-sm mb-0">Novas orientações e dicas terapêuticas aparecerão aqui assim que as sessões forem realizadas.</p>
                </div>
            }
        </div>
        
        <!-- Devolutivas Periódicas -->
        <div class="col-lg-5 mb-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h4 class="fw-bold text-dark mb-0"><i class="fa fa-file-text-o me-2 text-primary"></i>Devolutivas Periódicas</h4>
                <span class="text-muted text-sm">Segurança & Ciente</span>
            </div>
            
            @if (Model.MyReports.Any())
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var report in Model.MyReports)
                    {
                        var patientName = Model.MyPatients.FirstOrDefault(p => p.Id == report.PatientId)?.Name ?? "Paciente";
                        <div class="card border-0 shadow-sm rounded-4 p-3" style="background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.5);">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <strong class="text-dark d-block">@report.Title</strong>
                                    <small class="text-muted">Período: @report.StartDate.ToString("dd/MM/yyyy") - @report.EndDate.ToString("dd/MM/yyyy")</small>
                                </div>
                                @{
                                    var badgeClass = report.Status == PeriodicReportStatus.SignedByResponsible ? "bg-success text-white" : "bg-warning text-dark";
                                    var statusText = report.Status == PeriodicReportStatus.SignedByResponsible ? "Assinado" : "Pendente Ciente";
                                }
                                <span class="badge @badgeClass rounded-pill fw-bold" style="font-size: 0.8rem;">@statusText</span>
                            </div>
                           
                           <p class="text-muted text-sm mb-3">
                               Este relatório evolutivo compila os avanços terapêuticos obtidos no período para <strong>@patientName</strong>.
                           </p>
                           
                           <div class="d-flex gap-2">
                               <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3 ViewReportDetailsButton" data-id="@report.Id">
                                   <i class="fa fa-search me-1"></i> Visualizar Detalhes
                               </button>
                               @if (report.Status == PeriodicReportStatus.Published)
                               {
                                   <button type="button" class="btn btn-sm btn-interactive rounded-pill px-3 OpenSignatureModalButton" data-id="@report.Id">
                                       <i class="fa fa-pencil me-1"></i> Dar Ciente Legal
                                   </button>
                               }
                               else if (report.Status == PeriodicReportStatus.SignedByResponsible)
                               {
                                   <button type="button" class="btn btn-sm btn-success rounded-pill px-3 DownloadPdfButton" data-id="@report.Id">
                                       <i class="fa fa-download me-1"></i> Baixar PDF
                                   </button>
                               }
                           </div>
                       </div>
                   }
               </div>
           }
           else
           {
               <div class="card border-0 shadow-sm text-center p-4 rounded-4" style="background: rgba(255,255,255,0.6);">
                   <div class="fs-1 text-muted mb-2">📝</div>
                   <h6 class="fw-bold text-dark mb-1">Nenhum relatório periódico emitido</h6>
                   <p class="text-muted text-sm mb-0">Seus relatórios e evoluções mensais ou bimestrais estarão listados aqui assim que publicados pelos terapeutas.</p>
               </div>
           }
       </div>
   </div>
}
else
{
    @if (Model.OnboardingStatus?.NeedsOnboarding == true)
    {
        <!-- Premium Onboarding Wizard (E4) -->
        <div class="row justify-content-center">
            <div class="col-lg-10 col-12">
                <div class="card border-0 shadow-lg glass-card mb-5 welcoming-banner" style="background: rgba(255, 255, 255, 0.85); border: 1px solid rgba(255, 255, 255, 0.5);">
                    <div class="card-body p-4 p-md-5">
                        <!-- Header -->
                        <div class="text-center mb-5">
                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 72px; height: 72px; background: linear-gradient(135deg, var(--color-mint-teal-base) 0%, var(--color-lavender-base) 100%); color: white; font-size: 2rem;">
                                🚀
                            </div>
                            <h2 class="fw-bold text-dark mb-2">Configure sua Clínica WeCare</h2>
                            <p class="text-muted text-sm">Estamos quase prontos! Siga as 3 etapas rápidas abaixo para configurar seu espaço de trabalho.</p>
                        </div>

                        <!-- Wizard Progress Stepper -->
                        <div class="d-flex justify-content-between align-items-center position-relative mb-5 px-md-5">
                            <div class="position-absolute start-0 end-0 bg-light" style="height: 4px; top: 50%; transform: translateY(-50%); z-index: 1;">
                                <div id="wizard-progress-bar" class="bg-gradient-success" style="width: 0%; height: 100%; transition: width 0.4s ease; background: var(--gradient-welcoming-interactive);"></div>
                            </div>
                            
                            <div class="wizard-step-node active text-center position-relative" data-step="1" style="z-index: 2;">
                                <div class="step-num rounded-circle d-flex align-items-center justify-content-center bg-white border border-primary fw-bold mx-auto mb-2 shadow-sm" style="width: 40px; height: 40px; color: var(--color-mint-teal-base); transition: all 0.3s ease;">1</div>
                                <span class="text-xs fw-bold text-dark">Clínica & Branding</span>
                            </div>
                            
                            <div class="wizard-step-node text-center position-relative" data-step="2" style="z-index: 2;">
                                <div class="step-num rounded-circle d-flex align-items-center justify-content-center bg-white border fw-bold mx-auto mb-2 shadow-sm" style="width: 40px; height: 40px; color: #6c757d; transition: all 0.3s ease;">2</div>
                                <span class="text-xs fw-bold text-muted">Primeiro Terapeuta</span>
                            </div>
                            
                            <div class="wizard-step-node text-center position-relative" data-step="3" style="z-index: 2;">
                                <div class="step-num rounded-circle d-flex align-items-center justify-content-center bg-white border fw-bold mx-auto mb-2 shadow-sm" style="width: 40px; height: 40px; color: #6c757d; transition: all 0.3s ease;">3</div>
                                <span class="text-xs fw-bold text-muted">Paciente & Família</span>
                            </div>
                        </div>

                        <!-- Form -->
                        <form id="onboardingForm" method="post" asp-page-handler="Onboarding">
                            <!-- Step 1: Clínica & Branding -->
                            <div class="wizard-panel active" data-step="1">
                                <h4 class="fw-bold mb-4 text-dark border-bottom pb-2" style="font-size: 1.25rem;"><i class="fa fa-building me-2 text-primary"></i>Passo 1: Detalhes da Clínica</h4>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold" asp-for="OnboardingInput.ClinicName">Nome da Clínica</label>
                                        <input type="text" class="form-control" asp-for="OnboardingInput.ClinicName" required placeholder="Ex: Clínica Viver Bem" />
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold" asp-for="OnboardingInput.ContactEmail">E-mail de Contato</label>
                                        <input type="email" class="form-control" asp-for="OnboardingInput.ContactEmail" required placeholder="Ex: contato@clinicaviver.com" />
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold" asp-for="OnboardingInput.PrimaryColor">Cor Primária (Marca)</label>
                                        <div class="input-group">
                                            <input type="color" class="form-control form-control-color w-25" asp-for="OnboardingInput.PrimaryColor" style="height: 38px;" />
                                            <input type="text" class="form-control w-75 hex-color-input" id="primary-color-hex" value="@Model.OnboardingInput.PrimaryColor" placeholder="#4da391" />
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold" asp-for="OnboardingInput.SecondaryColor">Cor Secundária (Marca)</label>
                                        <div class="input-group">
                                            <input type="color" class="form-control form-control-color w-25" asp-for="OnboardingInput.SecondaryColor" style="height: 38px;" />
                                            <input type="text" class="form-control w-75 hex-color-input" id="secondary-color-hex" value="@Model.OnboardingInput.SecondaryColor" placeholder="#8c7fcd" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 2: Primeiro Terapeuta -->
                            <div class="wizard-panel d-none" data-step="2">
                                <h4 class="fw-bold mb-4 text-dark border-bottom pb-2" style="font-size: 1.25rem;"><i class="fa fa-user-md me-2 text-success"></i>Passo 2: Cadastro do Terapeuta Principal</h4>
                                <p class="text-muted text-sm mb-4">Crie a conta de acesso do profissional que irá acompanhar os primeiros pacientes da clínica.</p>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold" asp-for="OnboardingInput.TherapistName">Nome Completo do Terapeuta</label>
                                        <input type="text" class="form-control" asp-for="OnboardingInput.TherapistName" required placeholder="Ex: Dra. Mariana Albuquerque" />
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold" asp-for="OnboardingInput.TherapistEmail">E-mail Profissional (Login)</label>
                                        <input type="email" class="form-control" asp-for="OnboardingInput.TherapistEmail" required placeholder="Ex: mariana@clinicaviver.com" />
                                    </div>
                                    <div class="col-md-12 mb-3">
                                        <label class="form-label fw-semibold" asp-for="OnboardingInput.TherapistSpecialization">Especialização Principal</label>
                                        <input type="text" class="form-control" asp-for="OnboardingInput.TherapistSpecialization" required placeholder="Ex: Psicologia ABA, Fonoaudiologia, Terapia Ocupacional" />
                                    </div>
                                </div>
                                <div class="alert alert-info text-dark rounded-3" style="font-size: 0.85rem; background: hsl(168, 76%, 95%); border: 1px solid var(--color-mint-teal-light);">
                                    <i class="fa fa-info-circle me-2 text-primary"></i>A senha inicial do terapeuta será configurada por padrão como <strong>Clinic123!</strong>. Ele poderá redefini-la no primeiro acesso.
                                </div>
                            </div>

                            <!-- Step 3: Cadastro do Paciente & Responsável -->
                            <div class="wizard-panel d-none" data-step="3">
                                <h4 class="fw-bold mb-4 text-dark border-bottom pb-2" style="font-size: 1.25rem;"><i class="fa fa-heart me-2 text-danger"></i>Passo 3: Primeiro Paciente & Familiar</h4>
                                <p class="text-muted text-sm mb-4">Cadastre a criança e o responsável para receberem os relatórios e visualizarem o Feed diário.</p>
                                
                                <div class="row mb-4">
                                    <div class="col-12"><h5 class="fw-bold text-primary mb-3" style="font-size: 1.05rem;">Responsável Financeiro / Tutor</h5></div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label fw-semibold" asp-for="OnboardingInput.ResponsibleName">Nome do Responsável</label>
                                        <input type="text" class="form-control" asp-for="OnboardingInput.ResponsibleName" required placeholder="Ex: Carlos Albuquerque" />
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label fw-semibold" asp-for="OnboardingInput.ResponsibleCpf">CPF do Responsável</label>
                                        <input type="text" class="form-control cpf-mask" asp-for="OnboardingInput.ResponsibleCpf" required placeholder="Ex: 123.456.789-01" maxlength="14" />
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label fw-semibold" asp-for="OnboardingInput.ResponsibleEmail">E-mail do Responsável (Login)</label>
                                        <input type="email" class="form-control" asp-for="OnboardingInput.ResponsibleEmail" required placeholder="Ex: carlos@gmail.com" />
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12"><h5 class="fw-bold text-primary mb-3" style="font-size: 1.05rem;">Criança / Paciente</h5></div>
                                    <div class="col-md-8 mb-3">
                                        <label class="form-label fw-semibold" asp-for="OnboardingInput.PatientName">Nome do Paciente</label>
                                        <input type="text" class="form-control" asp-for="OnboardingInput.PatientName" required placeholder="Ex: Lucas Albuquerque" />
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label fw-semibold" asp-for="OnboardingInput.PatientBirthDate">Data de Nascimento</label>
                                        <input type="date" class="form-control" asp-for="OnboardingInput.PatientBirthDate" required />
                                    </div>
                                </div>
                                <div class="alert alert-info text-dark rounded-3 mt-3" style="font-size: 0.85rem; background: hsl(262, 70%, 95%); border: 1px solid var(--color-lavender-light);">
                                    <i class="fa fa-info-circle me-2 text-primary"></i>A senha inicial do responsável será configurada por padrão como <strong>Parent123!</strong>. O portal da família será liberado automaticamente após a conclusão.
                                </div>
                            </div>

                            <!-- Wizard Buttons -->
                            <div class="d-flex justify-content-between mt-5 border-top pt-4">
                                <button type="button" id="btn-prev" class="btn btn-outline-secondary rounded-pill px-4 d-none">
                                    <i class="fa fa-arrow-left me-2"></i> Voltar
                                </button>
                                <span class="flex-grow-1"></span>
                                <button type="button" id="btn-next" class="btn btn-interactive rounded-pill px-4">
                                    Próximo <i class="fa fa-arrow-right ms-2"></i>
                                </button>
                                <button type="submit" id="btn-submit" class="btn btn-success rounded-pill px-4 d-none btn-interactive" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); box-shadow: 0 4px 15px rgba(16, 185, 129, 0.2);">
                                    <i class="fa fa-check me-2"></i> Concluir e Iniciar
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @if (CurrentUser.IsAuthenticated)
        {
            <!-- Upgrades & Trial Notice Banner for Clinic Admins -->
            @if (CurrentUser.IsInRole("admin") && Model.Subscription != null)
            {
                @if (Model.Subscription.Status == "ActiveTrial")
                {
                    var daysLeft = (Model.Subscription.TrialEndDate.HasValue) ? Math.Max(0, (Model.Subscription.TrialEndDate.Value - DateTime.UtcNow).Days) : 14;
