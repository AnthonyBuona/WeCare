                                    <i class="fa fa-users me-1"></i> Meus Pacientes
                                </a>
                                <a href="/Calendar" class="btn btn-sm btn-outline-secondary bg-white rounded-pill px-3 shadow-sm" style="border: 1px solid rgba(0,0,0,0.12); color: #4b5563;">
                                    <i class="fa fa-calendar me-1"></i> Agenda
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        @if (CurrentUser.IsAuthenticated && Model.Stats != null)
