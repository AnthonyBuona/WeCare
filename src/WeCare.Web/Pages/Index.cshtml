                                    <p class="text-muted mb-0" style="font-size: 0.95rem;">@Model.ClinicInfo.WelcomeMessage</p>
                                }
                                else
                                {
                                    <p class="text-muted mb-0" style="font-size: 0.95rem;">Acompanhe os atendimentos, agenda e a evolução clínica de seus pacientes em tempo real.</p>
