                            <div class="card-body position-relative z-1 text-white">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="text-uppercase ls-1 mb-1" style="font-size: 0.7rem; color: rgba(255,255,255,0.6);">Consultas Hoje</h6>
                                        <h2 class="display-4 fw-bold mb-0 text-white">@Model.Stats.ConsultationsToday</h2>
                                    </div>
                                    <div class="icon-shape bg-white rounded-circle shadow" style="color: #f5576c;">
                                        <i class="fa fa-calendar-check-o fa-lg"></i>
                                    </div>
                                </div>
                                <p class="mt-3 mb-0 text-sm" style="color: rgba(255,255,255,0.6);">
                                    <span class="text-white fw-bold"><i class="fa fa-clock-o"></i> Agendadas</span> para hoje
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- KPI 4: Consultas este Mês -->
                    <div class="col-md-4 col-xl-2 mb-4">
                        <div class="card bg-gradient-info border-0 h-100 position-relative overflow-hidden">
                            <div class="card-body position-relative z-1 text-white">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="text-uppercase text-white-50 ls-1 mb-1" style="font-size: 0.7rem;">Consultas / Mês</h6>
                                        <h2 class="display-4 fw-bold mb-0 text-white">@Model.Stats.ConsultationsThisMonth</h2>
                                    </div>
                                    <div class="icon-shape bg-white text-info rounded-circle shadow">
