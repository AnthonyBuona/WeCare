                        <span class="text-xs text-muted fw-bold"><i class="fa fa-check-circle text-success me-1"></i> Assinatura WeCare Ativa (Plano @Model.Subscription.PlanName) — Obrigado por apoiar nossa plataforma!</span>
                        <button type="button" class="btn btn-outline-primary btn-xs rounded-pill" data-bs-toggle="modal" data-bs-target="#UpgradePlanModal">Alterar Plano</button>
                    </div>
                }
            }

            <div class="welcoming-banner shadow-sm mb-4">
                <div class="row align-items-center">
