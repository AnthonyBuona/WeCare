@page
@using WeCare.Localization
@using WeCare.Web.Pages.Patients
@using Microsoft.Extensions.Localization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@model WeCare.Web.Pages.Patients.SessionRecordModalModel

@inject IStringLocalizer<WeCareResource> L
@{
    Layout = null;
}
<form asp-page="/Patients/SessionRecordModal" id="SessionRecordForm">
    <input type="hidden" asp-for="PatientId" />
    <abp-modal size="Large">
        <abp-modal-header title="Registrar Nova Sessão: @Model.PatientName"></abp-modal-header>
        <abp-modal-body>
            <ul class="nav nav-pills nav-justified mb-4" id="sessionWizardTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active rounded-pill fw-bold" id="step1-tab" data-bs-toggle="pill" data-bs-target="#step1" type="button" role="tab" aria-selected="true">
                        <i class="fa fa-check-square me-2"></i> 1. Presença & Nota
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link rounded-pill fw-bold" id="step2-tab" data-bs-toggle="pill" data-bs-target="#step2" type="button" role="tab" aria-selected="false">
                        <i class="fa fa-bullseye me-2"></i> 2. Metas & Objetivos
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link rounded-pill fw-bold" id="step3-tab" data-bs-toggle="pill" data-bs-target="#step3" type="button" role="tab" aria-selected="false">
                        <i class="fa fa-calendar me-2"></i> 3. Próxima Consulta
                    </button>
                </li>
            </ul>

            <div class="tab-content" id="sessionWizardContent" style="min-height: 250px;">
                <!-- Step 1: Attendance & Notes -->
                <div class="tab-pane fade show active" id="step1" role="tabpanel">
                    <div class="row">
                        <div class="col-md-6">
                            <abp-input asp-for="Input.SessionDate" label="Data da Sessão" />
                        </div>
                        <div class="col-md-6">
                            <abp-select asp-for="Input.Status" label="Status de Frequência" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <abp-input asp-for="Input.SessionNotes" rows="5" label="Evolução Clínica / Observações da Sessão" placeholder="Escreva os detalhes da sessão, comportamento do paciente, treinos realizados e evolução clínica observada..." />
                    </div>
                    
                    <div class="text-end mt-4">
                        <button type="button" class="btn btn-primary rounded-pill px-4 next-step">Próximo: Objetivos <i class="fa fa-arrow-right ms-2"></i></button>
                    </div>
                </div>

                <!-- Step 2: Objectives Milestones -->
                <div class="tab-pane fade" id="step2" role="tabpanel">
                    <h5 class="fw-bold text-dark mb-3"><i class="fa fa-bullseye text-danger me-2"></i>Atualizar Progresso das Metas</h5>
                    <p class="text-muted text-sm mb-4">Selecione o progresso atual das metas do paciente observadas durante a sessão.</p>

                    @if (Model.ActiveObjectives != null && Model.ActiveObjectives.Any())
                    {
                        <div class="list-group list-group-flush rounded-3 border">
                            @foreach (var objective in Model.ActiveObjectives)
                            {
                                <div class="list-group-item p-3 d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1 fw-bold text-dark">@objective.Name</h6>
                                        <span class="text-xs text-muted">Status Atual: <span class="badge bg-light text-dark border">@objective.Status</span></span>
                                    </div>
                                    <div style="min-width: 200px;">
                                        <select name="Input.ObjectiveProgress[@objective.Id]" class="form-select form-select-sm rounded-pill">
                                            <option value="">-- Sem alteração --</option>
                                            <option value="Ativo">Ativo</option>
                                            <option value="Concluído">Concluído</option>
                                        </select>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info py-3 border-0 shadow-sm rounded-3">
                            <i class="fa fa-info-circle me-2"></i> O paciente não possui metas ou objetivos terapêuticos ativos. Você pode cadastrar objetivos na aba de Objetivos.
                        </div>
                    }

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4 prev-step"><i class="fa fa-arrow-left me-2"></i> Voltar</button>
                        <button type="button" class="btn btn-primary rounded-pill px-4 next-step">Próximo: Agendar <i class="fa fa-arrow-right ms-2"></i></button>
                    </div>
                </div>

                <!-- Step 3: Next Schedule -->
                <div class="tab-pane fade" id="step3" role="tabpanel">
                    <h5 class="fw-bold text-dark mb-3"><i class="fa fa-calendar text-primary me-2"></i>Agendar Próxima Consulta</h5>
                    <p class="text-muted text-sm mb-4">Escolha se deseja agendar automaticamente a próxima consulta do paciente para dar continuidade ao acompanhamento.</p>

                    <div class="card p-3 border-0 bg-light rounded-3 mb-4">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" role="switch" id="ScheduleNextSessionCheck" name="Input.ScheduleNextSession" value="true">
                            <label class="form-check-label fw-bold text-dark" for="ScheduleNextSessionCheck">Agendar Próxima Sessão no Calendário</label>
                        </div>

                        <div id="ScheduleFormSection" style="display: none;">
                            <div class="row">
                                <div class="col-md-6">
                                    <abp-input asp-for="Input.NextSessionDate" label="Data e Hora da Próxima Consulta" />
                                </div>
                                <div class="col-md-6">
                                    <abp-select asp-for="Input.NextSessionTherapistId" asp-items="Model.TherapistList" label="Terapeuta Responsável" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4 prev-step"><i class="fa fa-arrow-left me-2"></i> Voltar</button>
                    </div>
                </div>
            </div>
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)"></abp-modal-footer>
    </abp-modal>
</form>

<script>
    $(function () {
        var $form = $('#SessionRecordForm');
        var $modal = $form.closest('.modal');
        var $saveButton = $modal.find('button[type="submit"]');

        // Translate the Save button text to Portuguese
        $saveButton.text('Salvar Sessão Rápida').addClass('rounded-pill px-4 btn-primary').removeClass('btn-secondary');
        $saveButton.hide();

        // Handle next step
        $('.next-step').click(function () {
            var activeTab = $('#sessionWizardTabs .nav-link.active').attr('id');
            if (activeTab === 'step1-tab') {
                $('#step2-tab').tab('show');
            } else if (activeTab === 'step2-tab') {
                $('#step3-tab').tab('show');
                $saveButton.show();
            }
        });

        // Handle prev step
        $('.prev-step').click(function () {
            var activeTab = $('#sessionWizardTabs .nav-link.active').attr('id');
            if (activeTab === 'step2-tab') {
                $('#step1-tab').tab('show');
            } else if (activeTab === 'step3-tab') {
                $('#step2-tab').tab('show');
                $saveButton.hide();
            }
        });

        // Toggle Schedule Section
        $('#ScheduleNextSessionCheck').change(function () {
            if ($(this).is(':checked')) {
                $('#ScheduleFormSection').slideDown();
            } else {
                $('#ScheduleFormSection').slideUp();
            }
        });

        // Ensure clicking tabs directly toggles the final submit button correctly
        $('button[data-bs-toggle="pill"]').on('shown.bs.tab', function (e) {
            if (e.target.id === 'step3-tab') {
                $saveButton.show();
            } else {
                $saveButton.hide();
            }
        });
    });
</script>
